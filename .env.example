PORT=5000
# Use your Atlas connection string, or local: mongodb://localhost:27017/guidexpert
# If Atlas fails (IP not whitelisted): add your IP in Atlas → Network Access, or set MONGODB_URI_FALLBACK for local MongoDB
MONGODB_URI=mongodb://localhost:27017/guidexpert
# MONGODB_URI_FALLBACK=mongodb://localhost:27017/guidexpert

# MSG91 SMS OTP (control.msg91.com) — put real values in .env, never commit
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_dlt_template_id
OTP_EXPIRY_MINUTES=5
# Privileged QA phones (comma-separated): fixed OTP, no SMS, full panel access
OTP_BYPASS_PHONES=8143266699,6304153659,8919926373
# OTP_BYPASS_PHONE=8143266699,6304153659,8919926373
OTP_BYPASS_CODE=123456
# Optional password for privileged admin user (username = phone)
PRIVILEGED_ADMIN_PASSWORD=

# MSG91 Slot Confirmation SMS Template (for transactional SMS after slot booking)
MSG91_SLOT_CONFIRMATION_TEMPLATE_ID=your_slot_confirmation_template_id

# MSG91 Reminder SMS Template (pre4hr: sent in a tight cron window near 4h before slot; see WA_PRE4HR_* below)
MSG91_REMINDER_TEMPLATE_ID=your_reminder_template_id

# MSG91 Meet Link SMS Template (meet: tight cron window near 1h before slot; see WA_MEET_*)
MSG91_MEETLINK_TEMPLATE_ID=your_meetlink_template_id

# MSG91 30-Min Live Reminder SMS Template (30min: tight cron window near 30m before slot; see WA_30MIN_*)
MSG91_30MIN_REMINDER_TEMPLATE_ID=your_30min_reminder_template_id

# Demo Meeting Link (for Meet Link SMS - maps to ##var## in template)
DEMO_MEETING_LINK=https://your-meeting-link.com

# Cron job secret key (for /api/cron/* — query ?key=, x-cron-key, or Bearer)
# Prefer GUIDEXPERT_CRON_SECRET if CRON_SECRET is already used for another app.
# CRON_SECRET=your_cron_secret_key
GUIDEXPERT_CRON_SECRET=your_guidexpert_cron_secret_key

# Pre4hr cron: deadline-backward band — slotDate in [now+offset−window, now+offset+slack] (defaults 4h / 10m / 0 slack).
# WA_PRE4HR_OFFSET_MS=14400000
# WA_PRE4HR_CRON_WINDOW_MS=600000
# Optional: extend upper bound past exact deadline if scheduler often fires late (ms, default 0).
# WA_SLOT_CRON_DEADLINE_FORWARD_SLACK_MS=0
# Meet link cron: same semantics (default 1h / 10m).
# WA_MEET_OFFSET_MS=3600000
# WA_MEET_CRON_WINDOW_MS=600000
# 30min cron: same semantics (default 30m / 10m).
# WA_30MIN_OFFSET_MS=1800000
# WA_30MIN_CRON_WINDOW_MS=600000

# Campaign retry gaps (minutes, comma-separated). Per-kind cooldownMinutes default to 0 so stage delays apply as configured.
# WA_PRE4HR_RETRY_DELAY_MINUTES=1,2
# WA_MEET_RETRY_DELAY_MINUTES=1,2
# WA_30MIN_RETRY_DELAY_MINUTES=1
# WA_PRE4HR_RETRY_COOLDOWN_MINUTES=0
# WA_MEET_RETRY_COOLDOWN_MINUTES=0
# WA_30MIN_RETRY_COOLDOWN_MINUTES=0

# Cron: per-submission claim TTL (ms) so overlapping workers cannot double-send the same reminder batch row.
# WA_CRON_CLAIM_TTL_MS=120000
# Campaign retries: max wall time from first attempt-1 terminal failure before the retry group is closed (ms, default 15m).
# WHATSAPP_CAMPAIGN_RETRY_MAX_WALL_MS=900000
# Stale submitted/sent rows without DLR enter awaiting_final_dlr after this age (ms, default 45m).
# WA_DLR_RECONCILE_STALE_MS=2700000
# Grace in awaiting_final_dlr before phase-2 terminal failed (ms, default 30m).
# WA_DLR_RECONCILE_GRACE_MS=1800000
# Reconciliation batch size per phase per pass (default 200, max 500).
# WA_DLR_RECONCILE_BATCH_LIMIT=200
# Max phase1→phase2 passes per retry-whatsapp tick (default 3).
# WA_DLR_RECONCILE_MAX_PASSES=3
# Warn when phase-2 finalize backlog exceeds this count (default 100).
# WA_RECONCILE_PHASE2_BACKLOG_WARN=100
# Cron health warning when last successful run is older than this (default 2× WA_PRE4HR_CRON_WINDOW_MS, min 20m).
# WA_CRON_HEALTH_MAX_AGE_MS=1200000

OTP_SECRET=strong_random_string
# CORS: production frontend; for local dev use http://localhost:5173
FRONTEND_URL=https://www.guidexpert.co.in

# Admin panel (JWT secret required for login; run scripts/seedAdmin.js to create first admin)
ADMIN_JWT_SECRET=your_strong_random_jwt_secret_here
# Optional: for seedAdmin.js (otherwise script will prompt)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_secure_password

# Counsellor portal (JWT for counsellor login; run scripts/seedCounsellor.js to create first counsellor)
COUNSELLOR_JWT_SECRET=your_strong_random_counsellor_jwt_secret_here
# Optional: COUNSELLOR_JWT_EXPIRES_IN=24h

# One-on-One Counselor portal (IITian/mentor guidance slots). Falls back to COUNSELLOR_JWT_SECRET if unset.
# ONE_ON_ONE_COUNSELOR_JWT_SECRET=your_one_on_one_counselor_jwt_secret_here
# Optional: ONE_ON_ONE_COUNSELOR_JWT_EXPIRES_IN=7d

# Webinar login (JWT for webinar OTP login; if unset, falls back to COUNSELLOR_JWT_SECRET)
# WEBINAR_JWT_SECRET=your_webinar_jwt_secret_here
# Optional: WEBINAR_JWT_EXPIRES_IN=24h

# Google Sheets (service account). Share sheet with sheets-sync@... (Editor).
# Preferred (local + hosting): full service account JSON as one line
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
# Or (local only): path to JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=config/sheets-service-account.json

GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SHEET_RANGE=Formresponses

# Influencer UTM link base URL (default: https://guidexpert.co.in/register)
# REGISTRATION_BASE_URL=https://guidexpert.co.in/register
# IIT counselling UTM “save to list” uses this base (default: https://guidexpert.co.in/iit-counselling)
# IIT_COUNSELLING_PAGE_URL=https://guidexpert.co.in/iit-counselling

# NW College Predictor API (earlywave) — proxy for counsellor college predictor tool.
# Without NW_PREDICTORS_ACCESS_TOKEN, the College Predictor tool shows demo data only.
NW_PREDICTORS_BASE_URL=https://nw-predictors-backend-beta.earlywave.in
NW_PREDICTORS_ACCESS_TOKEN=your_nw_oauth2_access_token
# Optional: force entrance exam sent to API (e.g. KCET) when API returns "Invalid entrance exam name enum"
# NW_PREDICTORS_ENTRANCE_EXAM_OVERRIDE=KCET
# Predictor POST: beta earlywave uses legacy { clientKeyDetailsId, data, branch_codes } (this is the default).
# For a host that matches OpenAPI/Swagger flat body (e.g. local Django from api_spec 69.json):
# NW_PREDICTORS_USE_OPENAPI_FLAT_BODY=true
# To force legacy off without the flag above: NW_PREDICTORS_LEGACY_WRAPPED_PAYLOAD=false
# Legacy wrapper only: inner JSON without extra single-quote wrapping (optional)
# NW_PREDICTORS_DATA_PLAIN=true

# Counsellor + WhatsApp college predictor read NW_PREDICTORS_ACCESS_TOKEN only (no separate WhatsApp env).

# OSVI outbound voice call (counselor Apply abandoned flow — optional; requires token + agent UUID)
# Delay before abandoned-flow outbound OSVI call runs after OTP (ms). Default: 600000 (10 min)
# OSVI_ABANDONED_DELAY_MS=600000
# POST https://api.osvi.ai/call — if DNS fails, try OSVI_CALL_URL=https://api.api.osvi.ai/call
# OSVI_API_TOKEN=your_18_char_osvi_api_token
# OSVI_AGENT_UUID=agent_xxxxxxxx  (required with OSVI_API_TOKEN or calls are not scheduled)
# OSVI_COUNTRY_CODE=IN
# OSVI_SYSTEM_PROMPT=Optional runtime prompt override for this agent on outbound calls
# OSVI_WEBHOOK_URL=https://yourdomain.com/osvi-webhook
# OSVI_CALL_URL=https://api.osvi.ai/call
# Permanent static bearer token for OSVI webhook ingestion endpoint (POST /api/osvi/call-session)
# OSVI_WEBHOOK_TOKEN=your_long_random_webhook_secret
# Permanent static bearer token for OSVI/admin integration endpoints (e.g. PATCH /api/admin/leads/slot-by-phone)
# OSVI_ADMIN_API_TOKEN=your_long_random_secret

# Gupshup WhatsApp — required on the API server for IIT slot confirmation, GX reminders, and chatbot replies.
# ENABLE_WHATSAPP=true
# GUPSHUP_API_KEY=your_api_key
# GUPSHUP_SOURCE=your_registered_whatsapp_sender_number
# Optional display name submitted to template API when required by provider:
# GUPSHUP_SRC_NAME=

# WhatsApp chatbot (inbound webhooks + session replies via POST /webhook/gupshup)
# Optional: when set, Gupshup must send the same value (x-webhook-secret header or ?secret= on callback URL).
# If unset, webhooks are accepted without auth until you add a secret (then auth is enforced automatically).
# GUPSHUP_WEBHOOK_SECRET=your_long_random_webhook_secret
# GUPSHUP_WEBHOOK_AUTH_REQUIRED=0
# Force auth before secret exists (503 if secret missing): GUPSHUP_WEBHOOK_AUTH_REQUIRED=1
# CHATBOT_ENABLED=1
# College predictor in WhatsApp (option 5 / menu_5). Off by default — maintenance message until enabled:
# CHATBOT_COLLEGE_PREDICTOR_ENABLED=1
# Main menu is always plain text (no CHATBOT_USE_BUTTON_MENU needed).
# Outside 24h session window — template fallback when Gupshup returns Re-engagement / 131047:
# CHATBOT_SESSION_FALLBACK_TEMPLATE_ENV=GUPSHUP_TEMPLATE_YOUR_NUDGE_ENV_KEY
# GUPSHUP_TEMPLATE_YOUR_NUDGE_ENV_KEY=<approved-template-uuid>
# CHATBOT_SESSION_FALLBACK_PARAM_NAME=optional_template_param
# CHATBOT_RATE_LIMIT_PER_MIN=12
# Phase 4 Sprint 1 — NVIDIA OpenAI-compatible LLM (knowledge assistant)
# CHATBOT_KNOWLEDGE_ASSISTANT_ENABLED=1
# LLM_API_KEY=
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=openai/gpt-oss-20b
# LLM_TIMEOUT_MS=20000
# LLM_MAX_RETRIES=2
# KNOWLEDGE_ASSISTANT_TIMEOUT_MS=8000
# Phase 5 — Knowledge indexing (embeddings stored in Mongo; vector search runtime deferred)
# EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
# EMBEDDING_DIMENSIONS=1024
# EMBEDDING_BATCH_SIZE=16
# EMBEDDING_API_KEY=  # optional; defaults to LLM_API_KEY
# EMBEDDING_BASE_URL=  # optional; defaults to LLM_BASE_URL
# Phase 5 — Runtime retrieval
# KNOWLEDGE_SEARCH_MODE=hybrid   # keyword | vector | hybrid
# KNOWLEDGE_VECTOR_INDEX_NAME=knowledge_vector_index
# KNOWLEDGE_VECTOR_NUM_CANDIDATES=50
# KNOWLEDGE_VECTOR_RECALL_LIMIT=20
# KNOWLEDGE_KEYWORD_RECALL_LIMIT=20
# KNOWLEDGE_HYBRID_KEYWORD_WEIGHT=0.45
# DEBUG_AI=true  # enable [KB]/[CTX]/[GUARDRAIL]/[LLM-DEBUG]/[LANG] logs
# Phase 6 — Multilingual Knowledge Assistant (English-pivot translation)
# CHATBOT_MULTILINGUAL_ENABLED=1
# LANGUAGE_DETECT_MIN_CONFIDENCE=0.75
# LANGUAGE_DETECT_LLM_FALLBACK=1
# TRANSLATION_TIMEOUT_MS=5000
# OUTBOUND_TRANSLATION_TIMEOUT_MS=12000  # long KA replies need more time after RAG+LLM
# TRANSLATION_PRESERVE_TERMS=CSE,ECE,MECH,NIAT,NAT,GuideXpert,IIT
# KNOWLEDGE_ASSISTANT_TIMEOUT_MS=12000  # allow +4-6s for detect + translate when multilingual on
# CHATBOT_INBOUND_DEDUPE_BUCKET_SEC=45  # collapse duplicate Gupshup/Meta webhooks for same text
# Legacy orchestrator alias: CHATBOT_LLM_ENABLED=1
# OPENAI_API_KEY= or CHATBOT_LLM_API_KEY= (deprecated; use LLM_API_KEY)
# GUPSHUP_CHATBOT_SEND_TIMEOUT_MS=20000
# Cron replay for failed outbound: GET /api/cron/process-chatbot-inbound?key=$CRON_SECRET
# GET /api/health returns whatsapp.* config flags (no secrets).

# 1-on-1 counseling form (/one-on-one-session) — immediate WhatsApp on submit
# GUPSHUP_TEMPLATE_ONE_ON_ONE_CONFIRM=901df6f6-860d-4e80-985c-e5b620c7f5b4
# GUPSHUP_ONE_ON_ONE_HEADER_IMAGE_URL=https://public-url/for-approved-template-header-image.jpg
# WA_ONE_ON_ONE_SUBMIT_RETRY_DELAY_SECONDS=15

# Guidance booking confirmation (/guidance-booking-confirmation) — immediate WhatsApp on book-slot
# GUPSHUP_TEMPLATE_GUIDANCE_BOOKING_CONFIRM=bf9dfb57-69c0-4ee9-8b8c-4b52d99cab3c
# WA_GUIDANCE_BOOKING_SUBMIT_RETRY_DELAY_SECONDS=15

# Manual check: POST /api/iit-counselling/section1 with JSON body that includes BOTH
# slotBooking ("Wednesday 6PM" | "Saturday 6PM" | "Sunday 11AM") AND slotBookingDate (YYYY-MM-DD,
# IST weekday must match slot). Without slotBookingDate the server skips WhatsApp silently.

# IIT counselling WhatsApp templates (Wed / Sat / Sun slot booked)
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_WEDNESDAY=da210654-4ab6-42df-8999-dfa9854ba1ca
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_SATURDAY=bfa01e16-0609-451f-94c2-756449a71847
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_SUNDAY=48267f24-b371-4344-b8e6-495467d5d5f6
# Required for IIT slot_booked (IMAGE header templates). Send fails if unset on production.
GUPSHUP_IIT_SLOT_BOOKED_HEADER_IMAGE_URL=https://res.cloudinary.com/dfqdb1xws/image/upload/v1779169268/image_1_opyelz.png
# Verbose IIT outbound payload logs (iit_wa_send_trace). Set 0 to disable after debugging.
# WA_IIT_SEND_TRACE=1
# Optional legacy fallback when the per-day var for the chosen slot is unset:
# GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED=

# IIT counselling language-aware reminders (scheduled on Section 2 save when preferredLanguage is set)
# Wed/Sat 6PM — 2 hours before slot
GUPSHUP_TEMPLATE_IIT_PRE2HR_TELUGU=
GUPSHUP_TEMPLATE_IIT_PRE2HR_HINDI=
# Pre2hr param retry profiles (| = separate attempts; none = static body): name|none|name,date,time
# GUPSHUP_IIT_PRE2HR_PARAM_PROFILES=name|none|name,date,time
# GUPSHUP_IIT_PRE2HR_HEADER_IMAGE_URL=
# Wed/Sat 6PM — 45 minutes before slot
GUPSHUP_TEMPLATE_IIT_PRE45MIN_TELUGU=
GUPSHUP_TEMPLATE_IIT_PRE45MIN_HINDI=
# Wed/Sat 6PM — 15 minutes before slot
GUPSHUP_TEMPLATE_IIT_PRE15MIN_TELUGU=
GUPSHUP_TEMPLATE_IIT_PRE15MIN_HINDI=
# Sunday 11AM — 2 hours before slot
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE2HR_TELUGU=
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE2HR_HINDI=
# Sunday 11AM — 45 minutes before slot
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE45MIN_TELUGU=
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE45MIN_HINDI=
# Sunday 11AM — 15 minutes before slot
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE15MIN_TELUGU=
GUPSHUP_TEMPLATE_IIT_SUNDAY_PRE15MIN_HINDI=

# IIT reminder offsets (ms before counsellingSlotInstantUtc; defaults: 2h / 45m / 15m)
# WA_IIT_PRE2HR_OFFSET_MS=7200000
# WA_IIT_PRE45MIN_OFFSET_MS=2700000
# WA_IIT_PRE15MIN_OFFSET_MS=900000
# Cron claim windows (mirror GX pre4hr/meet/30min if unset)
# WA_IIT_PRE2HR_CRON_WINDOW_MS=600000
# WA_IIT_PRE45MIN_CRON_WINDOW_MS=600000
# WA_IIT_PRE15MIN_CRON_WINDOW_MS=600000
# Optional: expire pending IIT reminder jobs after slot + grace
# WA_IIT_PRE15MIN_EXPIRE_GRACE_MS=
# WA_IIT_REMINDER_JOB_TTL_MS=
# External cron (every 1 min): GET /api/cron/send-iit-reminders?key=$CRON_SECRET

# IIT counselling Telugu SMS (MSG91 Flow — parallel to GX demo SMS; does not replace existing templates)
# STPL template IDs (defaults in config/iitTeluguSmsTemplates.js if unset):
# MSG91_IIT_TELUGU_SMS_TMINUS_1D_TEMPLATE_ID=1707177970525757388
# MSG91_IIT_TELUGU_SMS_TMINUS_2H_TEMPLATE_ID=1707177970552845186
# MSG91_IIT_TELUGU_SMS_SESSION_8AM_TEMPLATE_ID=1707177970535787192
# MSG91_IIT_TELUGU_SMS_TMINUS_30M_TEMPLATE_ID=1707177970579426973
# MSG91_IIT_TELUGU_SMS_TMINUS_5M_TEMPLATE_ID=1707177977442936157
# MSG91_IIT_TELUGU_SMS_TPLUS_5M_TEMPLATE_ID=1707177977449694822
# Meet link for T-30m / T-5m / T+5m Telugu SMS only (MSG91 ##var##; static templates need no vars)
# IIT_COUNSELLING_MEET_LINK=https://www.guidexpert.co.in/iitcounsellingmeet
# Cron dispatch window after scheduledSendAt (ms, default 10m)
# IIT_TELUGU_SMS_CRON_WINDOW_MS=600000
# IIT_TELUGU_SMS_MAX_ATTEMPTS=3
# External cron (every 1 min): GET /api/cron/send-iit-telugu-sms?key=$GUIDEXPERT_CRON_SECRET
#   (NOT send-iit-reminders — that is IIT WhatsApp only.)
#   Create job: https://console.cron-job.org/jobs/create  |  npm run cron:url:iit-telugu-sms
#   Docs: docs/cron-iit-telugu-sms.md
# Local dev loop: DEV_IIT_TELUGU_SMS_CRON_LOOP=1
