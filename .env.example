PORT=5000
# Use your Atlas connection string, or local: mongodb://localhost:27017/guidexpert
# If Atlas fails (IP not whitelisted): add your IP in Atlas → Network Access, or set MONGODB_URI_FALLBACK for local MongoDB
MONGODB_URI=mongodb://localhost:27017/guidexpert
# MONGODB_URI_FALLBACK=mongodb://localhost:27017/guidexpert

# MSG91 SMS OTP (control.msg91.com) — put real values in .env, never commit
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_dlt_template_id
OTP_EXPIRY_MINUTES=5

# MSG91 Slot Confirmation SMS Template (for transactional SMS after slot booking)
MSG91_SLOT_CONFIRMATION_TEMPLATE_ID=your_slot_confirmation_template_id

# MSG91 Reminder SMS Template (pre4hr: sent in a tight cron window near 4h before slot; see WA_PRE4HR_* below)
MSG91_REMINDER_TEMPLATE_ID=your_reminder_template_id

# MSG91 Meet Link SMS Template (meet: tight cron window near 1h before slot; see WA_MEET_*)
MSG91_MEETLINK_TEMPLATE_ID=your_meetlink_template_id

# MSG91 30-Min Live Reminder SMS Template (30min: tight cron window near 30m before slot; see WA_30MIN_*)
MSG91_30MIN_REMINDER_TEMPLATE_ID=your_30min_reminder_template_id

# Demo Meeting Link (for Meet Link SMS - maps to ##var## in template)
DEMO_MEETING_LINK=https://your-meeting-link.com

# Cron job secret key (for /api/cron/* — query ?key=, x-cron-key, or Bearer)
# Prefer GUIDEXPERT_CRON_SECRET if CRON_SECRET is already used for another app.
# CRON_SECRET=your_cron_secret_key
GUIDEXPERT_CRON_SECRET=your_guidexpert_cron_secret_key

# Pre4hr cron: deadline-backward band — slotDate in [now+offset−window, now+offset+slack] (defaults 4h / 10m / 0 slack).
# WA_PRE4HR_OFFSET_MS=14400000
# WA_PRE4HR_CRON_WINDOW_MS=600000
# Optional: extend upper bound past exact deadline if scheduler often fires late (ms, default 0).
# WA_SLOT_CRON_DEADLINE_FORWARD_SLACK_MS=0
# Meet link cron: same semantics (default 1h / 10m).
# WA_MEET_OFFSET_MS=3600000
# WA_MEET_CRON_WINDOW_MS=600000
# 30min cron: same semantics (default 30m / 10m).
# WA_30MIN_OFFSET_MS=1800000
# WA_30MIN_CRON_WINDOW_MS=600000

# Campaign retry gaps (minutes, comma-separated). Per-kind cooldownMinutes default to 0 so stage delays apply as configured.
# WA_PRE4HR_RETRY_DELAY_MINUTES=1,2
# WA_MEET_RETRY_DELAY_MINUTES=1,2
# WA_30MIN_RETRY_DELAY_MINUTES=1
# WA_PRE4HR_RETRY_COOLDOWN_MINUTES=0
# WA_MEET_RETRY_COOLDOWN_MINUTES=0
# WA_30MIN_RETRY_COOLDOWN_MINUTES=0

# Cron: per-submission claim TTL (ms) so overlapping workers cannot double-send the same reminder batch row.
# WA_CRON_CLAIM_TTL_MS=120000
# Campaign retries: max wall time from first attempt-1 terminal failure before the retry group is closed (ms, default 5m).
# WHATSAPP_CAMPAIGN_RETRY_MAX_WALL_MS=300000

OTP_SECRET=strong_random_string
# CORS: production frontend; for local dev use http://localhost:5173
FRONTEND_URL=https://www.guidexpert.co.in

# Admin panel (JWT secret required for login; run scripts/seedAdmin.js to create first admin)
ADMIN_JWT_SECRET=your_strong_random_jwt_secret_here
# Optional: for seedAdmin.js (otherwise script will prompt)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=your_secure_password

# Counsellor portal (JWT for counsellor login; run scripts/seedCounsellor.js to create first counsellor)
COUNSELLOR_JWT_SECRET=your_strong_random_counsellor_jwt_secret_here
# Optional: COUNSELLOR_JWT_EXPIRES_IN=24h

# Webinar login (JWT for webinar OTP login; if unset, falls back to COUNSELLOR_JWT_SECRET)
# WEBINAR_JWT_SECRET=your_webinar_jwt_secret_here
# Optional: WEBINAR_JWT_EXPIRES_IN=24h

# Google Sheets (service account). Share sheet with sheets-sync@... (Editor).
# Preferred (local + hosting): full service account JSON as one line
GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
# Or (local only): path to JSON key file
# GOOGLE_APPLICATION_CREDENTIALS=config/sheets-service-account.json

GOOGLE_SHEET_ID=your_sheet_id_from_url
GOOGLE_SHEET_RANGE=Formresponses

# Influencer UTM link base URL (default: https://guidexpert.co.in/register)
# REGISTRATION_BASE_URL=https://guidexpert.co.in/register
# IIT counselling UTM “save to list” uses this base (default: https://guidexpert.co.in/iit-counselling)
# IIT_COUNSELLING_PAGE_URL=https://guidexpert.co.in/iit-counselling

# NW College Predictor API (earlywave) — proxy for counsellor college predictor tool.
# Without NW_PREDICTORS_ACCESS_TOKEN, the College Predictor tool shows demo data only.
NW_PREDICTORS_BASE_URL=https://nw-predictors-backend-beta.earlywave.in
NW_PREDICTORS_ACCESS_TOKEN=your_nw_oauth2_access_token
# Optional: force entrance exam sent to API (e.g. KCET) when API returns "Invalid entrance exam name enum"
# NW_PREDICTORS_ENTRANCE_EXAM_OVERRIDE=KCET
# Predictor POST: beta earlywave uses legacy { clientKeyDetailsId, data, branch_codes } (this is the default).
# For a host that matches OpenAPI/Swagger flat body (e.g. local Django from api_spec 69.json):
# NW_PREDICTORS_USE_OPENAPI_FLAT_BODY=true
# To force legacy off without the flag above: NW_PREDICTORS_LEGACY_WRAPPED_PAYLOAD=false
# Legacy wrapper only: inner JSON without extra single-quote wrapping (optional)
# NW_PREDICTORS_DATA_PLAIN=true

# CollegeDost College Predictor API — per-exam endpoints (collegedost.in)
COLLEGEDOST_ACCESS_TOKEN=your_collegedost_bearer_token

# OSVI outbound voice call (counselor Apply abandoned flow — optional; requires token + agent UUID)
# Delay before abandoned-flow outbound OSVI call runs after OTP (ms). Default: 600000 (10 min)
# OSVI_ABANDONED_DELAY_MS=600000
# POST https://api.osvi.ai/call — if DNS fails, try OSVI_CALL_URL=https://api.api.osvi.ai/call
# OSVI_API_TOKEN=your_18_char_osvi_api_token
# OSVI_AGENT_UUID=agent_xxxxxxxx  (required with OSVI_API_TOKEN or calls are not scheduled)
# OSVI_COUNTRY_CODE=IN
# OSVI_SYSTEM_PROMPT=Optional runtime prompt override for this agent on outbound calls
# OSVI_WEBHOOK_URL=https://yourdomain.com/osvi-webhook
# OSVI_CALL_URL=https://api.osvi.ai/call
# Permanent static bearer token for OSVI webhook ingestion endpoint (POST /api/osvi/call-session)
# OSVI_WEBHOOK_TOKEN=your_long_random_webhook_secret
# Permanent static bearer token for OSVI/admin integration endpoints (e.g. PATCH /api/admin/leads/slot-by-phone)
# OSVI_ADMIN_API_TOKEN=your_long_random_secret

# Gupshup WhatsApp — required on the API server for IIT slot confirmation and GX reminders.
# ENABLE_WHATSAPP=true
# GUPSHUP_API_KEY=your_api_key
# GUPSHUP_SOURCE=your_registered_whatsapp_sender_number
# Optional display name submitted to template API when required by provider:
# GUPSHUP_SRC_NAME=

# Manual check: POST /api/iit-counselling/section1 with JSON body that includes BOTH
# slotBooking ("Wednesday 6PM" | "Saturday 6PM" | "Sunday 11AM") AND slotBookingDate (YYYY-MM-DD,
# IST weekday must match slot). Without slotBookingDate the server skips WhatsApp silently.

# IIT counselling WhatsApp templates (Wed / Sat / Sun slot booked)
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_WEDNESDAY=da210654-4ab6-42df-8999-dfa9854ba1ca
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_SATURDAY=bfa01e16-0609-451f-94c2-756449a71847
GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED_SUNDAY=48267f24-b371-4344-b8e6-495467d5d5f6
# Optional legacy fallback when the per-day var for the chosen slot is unset:
# GUPSHUP_TEMPLATE_IIT_SLOT_BOOKED=
