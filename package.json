{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --config nodemon.json server.js",
    "dev:node": "node --watch server.js",
    "seed": "node scripts/seed.js",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:training-form": "node scripts/seedTrainingFormResponses.js",
    "seed:training-meet-attendance": "node scripts/seedTrainingMeetingAttendance.js",
    "seed:blogs": "node scripts/seedBlogs.js",
    "backfill:webinar-feedback": "node scripts/backfillWebinarCompletionFromFeedback.js",
    "backfill:student-createdby": "node scripts/backfillStudentCreatedBy.js",
    "migrate:iit-counselling": "node scripts/migrateIitCounsellingToDedicatedCollection.js",
    "migrate:iit-counselling:delete-source": "node scripts/migrateIitCounsellingToDedicatedCollection.js --delete-source",
    "test": "npm run test:whatsapp-all",
    "test:integration": "node --test --test-concurrency=1 test/integration/suites/*.test.js",
    "test:integration:race": "node --test --test-concurrency=1 test/integration/suites/lateWebhookReconcile.test.js test/integration/suites/cronOverlap.test.js test/integration/suites/dispatchCrashRecovery.test.js test/integration/suites/retryPromotion.test.js test/integration/suites/manualRecoveryOverlap.test.js",
    "test:integration:reconcile": "node --test test/integration/suites/lateWebhookReconcile.test.js",
    "test:integration:stress": "WA_INTEGRATION_STRESS=1 node --test test/integration/stress/*.test.js",
    "test:whatsapp-all": "node --test test/*.test.js test/integration/suites/*.test.js",
    "test:poster-track": "node scripts/testPosterTrackKeys.js",
    "test:gupshup-webhook": "node --test test/gupshupWebhookFlow.test.js",
    "test:whatsapp-retry-rules": "node --test test/whatsappRetryRules.test.js",
    "test:demo-meet-live-windows": "node --test test/demoMeetLiveWindows.test.js",
    "backfill:wa-retry-groups": "node scripts/backfillWhatsAppMessageEventRetryGroups.js",
    "backfill:wa-reconcile-derived": "node scripts/backfillReconcileDerivedFailure.js",
    "backfill:wa-reminder-jobs": "node scripts/backfillWhatsAppReminderJobs.js",
    "backfill:iit-reminder-jobs": "node scripts/backfillIitReminderJobs.js",
    "requeue:iit-reminder-jobs": "node scripts/requeueIitReminderJobs.js",
    "requeue:iit-reminder-jobs:dispatch": "node scripts/requeueIitReminderJobs.js --dispatch",
    "repair:iit-retry-funnel": "node scripts/repairIitRetryFunnel.js",
    "repair:iit-retry-funnel:execute": "node scripts/repairIitRetryFunnel.js --execute",
    "replay:iit-webhook-dlr": "node scripts/replayIitWebhookDlr.js",
    "sync:wa-reminder-indexes": "node -e \"require('dotenv').config();const m=require('mongoose');const J=require('./models/WhatsAppReminderJob');m.connect(process.env.MONGODB_URI).then(()=>J.syncIndexes()).then(()=>{console.log('synced');return m.disconnect();});\"",
    "test:whatsapp-reminder-p3": "node --test test/whatsappReminder*.test.js test/backfillWhatsAppReminderJobs.test.js",
    "test:whatsapp-reminder-hardening": "node --test test/whatsappReminderJobHardening.test.js test/whatsappReminder*.test.js test/backfillWhatsAppReminderJobs.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sripavantejb/GuideXpert-Backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/sripavantejb/GuideXpert-Backend/issues"
  },
  "homepage": "https://github.com/sripavantejb/GuideXpert-Backend#readme",
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "@vercel/functions": "^3.4.3",
    "archiver": "^8.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "googleapis": "^170.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "mongoose": "^9.1.5",
    "nodemon": "^3.1.11"
  },
  "devDependencies": {
    "mongodb-memory-server": "^10.4.3"
  }
}
