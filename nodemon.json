{
  "watch": ["server.js", "routes", "controllers", "models", "middleware", "config", "services", "utils"],
  "ext": "js,json",
  "delay": 2500,
  "legacyWatch": true,
  "ignore": [
    "node_modules/**",
    "data/**",
    "*.test.js",
    ".git/**",
    ".env",
    ".env.*",
    "*.md",
    "package-lock.json"
  ]
}
