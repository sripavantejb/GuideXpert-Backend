# Copy to .env.gupshup.local and paste Production values from Vercel → guide-xpert-backend → Environment Variables → Reveal.
# Or run: GUPSHUP_API_KEY=... GUPSHUP_SOURCE=... node scripts/set-gupshup-local-env.js
# This file is gitignored; never commit real keys.

ENABLE_WHATSAPP=true
WA_INTEGRATION_STUB=0
GUPSHUP_API_KEY=your_gupshup_api_key_from_vercel
GUPSHUP_SOURCE=91XXXXXXXXXX
