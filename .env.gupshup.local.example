# Copy to .env.gupshup.local (gitignored). Values from Vercel → Project → Settings → Environment Variables (Production).
# Same GUPSHUP_API_KEY and GUPSHUP_SOURCE used for IIT slot booked / one-on-one on production.
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_SOURCE=your_registered_whatsapp_sender_number_e164_without_plus

# Optional: set WA_INTEGRATION_STUB=1 to test Ops audit rows locally without hitting Gupshup (no real WhatsApp).
# WA_INTEGRATION_STUB=1
